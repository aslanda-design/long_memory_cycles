# Operating system files
.DS_Store
Thumbs.db

# Editors and local workspace settings
.idea/
.vscode/
*.swp
*.swo

# Local environment and secrets
.env
.env.*
!.env.example
.python-version

# Python bytecode and extension modules
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging and build artifacts
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# Test, coverage, linting, and type-check caches
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.mypy_cache/
.pyre/
.ruff_cache/
.hypothesis/

# Documentation build output
site/

# Jupyter transient files
.ipynb_checkpoints/
*.nbconvert.ipynb

# Data and generated research artifacts.
# Keep lightweight README/.gitkeep files so the folder structure can be documented.
data/*
!data/.gitkeep
!data/README*
models/*
!models/.gitkeep
!models/README*
outputs/
artifacts/

# Serialized arrays/models that are usually reproducible from notebooks or scripts
*.pkl
*.pickle
*.joblib
*.npy
*.npz
*.h5
*.hdf5
*.parquet
*.feather

# Logs
*.log

#figures
figures/
models/
